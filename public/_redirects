# Legacy redirect rules
# 규칙: dist/에 콘텐츠 페이지가 존재하면 여기에 넣지 말 것
# 검증: bash scripts/qa-redirects.sh
# 참고: 코인 대소문자 리다이렉트는 _worker.js에서 처리 (Cloudflare 100개 제한)

# /en/ → / (English is root, hreflang points to /)
/en /  301
/en/* /:splat 301

/builder /simulate/ 301
/builder/* /simulate/ 301
/simulator /simulate/ 301
/simulator/* /simulate/ 301

# /performance page exists — no redirect needed

/sitemap.xml /sitemap-index.xml 301

# /ranking/ and /rankings/ → canonical /strategies/ranking
/ranking /strategies/ranking 301
/ranking/ /strategies/ranking 301
/rankings /strategies/ranking 301
/rankings/ /strategies/ranking 301

# /compare/binance-vs-okx → /fees (exchange comparison lives on fees page).
# Handled by src/pages/compare/binance-vs-okx.astro at build time; this line
# is a belt-and-suspenders for direct edge hits before the Astro route resolves.
/compare/binance-vs-okx /fees 301
/compare/binance-vs-okx/ /fees 301

# Blog slug renames (why-backtests-fail → why-backtests-lie)
/blog/why-backtests-fail /blog/why-backtests-lie/ 301
/blog/why-backtests-fail/ /blog/why-backtests-lie/ 301
/ko/blog/why-backtests-fail /ko/blog/why-backtests-lie/ 301
/ko/blog/why-backtests-fail/ /ko/blog/why-backtests-lie/ 301

# KO equivalents
/ko/builder /ko/simulate/ 301
/ko/builder/* /ko/simulate/ 301
# /ko/performance page exists — no redirect needed
/ko/ranking /ko/strategies/ranking 301
/ko/ranking/ /ko/strategies/ranking 301
/ko/rankings /ko/strategies/ranking 301
/ko/rankings/ /ko/strategies/ranking 301
