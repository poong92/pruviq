.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
# runtime uvicorn / backend process logs — must never be committed to a
# public repo (they leak server PIDs, internal error traces, retry
# patterns). The directory stays on disk for local ops; git just ignores.
logs/
*.log


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# Python backend
backend/data/
backend/.venv/
backend/__pycache__/
backend/src/__pycache__/
**/__pycache__/
*.pyc
*.pyo
data/
!src/data/
!public/data/
# Ignore generated cache files (CoinGecko coin-list etc.)
data_cache/
test-results/
playwright-report/
reports/
.claude-active
docs/design-audit-20260324/

