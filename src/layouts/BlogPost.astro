---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  category: string;
  author?: string;
  image?: string;
  tags?: string[];
}

const { title, description, date, category, author = 'PRUVIQ Research', image, tags = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  market: 'MARKET ANALYSIS',
  quant: 'QUANT CONCEPTS',
  strategy: 'STRATEGY UPDATE',
  weekly: 'WEEKLY REVIEW',
  education: 'EDUCATION',
};

// Tag → simulator preset mapping for contextual CTA
const tagPresetMap: Record<string, { preset: string; label: string }> = {
  'rsi': { preset: 'rsi-reversal', label: 'RSI Reversal' },
  'macd': { preset: 'macd-cross', label: 'MACD Cross' },
  'ema': { preset: 'ema-crossover', label: 'EMA Crossover' },
  'bollinger-bands': { preset: 'bb-squeeze-short', label: 'BB Squeeze' },
  'squeeze': { preset: 'bb-squeeze-short', label: 'BB Squeeze' },
  'ichimoku': { preset: 'ichimoku', label: 'Ichimoku Cloud' },
  'stochastic': { preset: 'stochastic-rsi', label: 'Stochastic RSI' },
  'adx': { preset: 'adx-trend', label: 'ADX Trend' },
  'atr': { preset: 'atr-breakout', label: 'ATR Breakout' },
  'volume': { preset: 'volume-breakout', label: 'Volume Breakout' },
  'vwap': { preset: 'vwap', label: 'VWAP' },
};
const matchedPreset = tags.map(t => tagPresetMap[t]).find(Boolean);
---

<Layout title={`${title} - PRUVIQ`} description={description} type="article" date={date} category={category} ogImage={image}>
  <article class="py-12">
    <div class="max-w-[45rem] mx-auto px-4">
      <a href="/learn" class="text-[--color-text-muted] text-sm hover:text-[--color-accent] transition-colors mb-8 inline-block">
        &larr; Back to Learn
      </a>

      <div class="mb-8">
        <span class="font-mono text-[--color-accent] text-xs tracking-wider">
          {categoryLabels[category] || category.toUpperCase()}
        </span>
        <h1 class="text-3xl md:text-4xl font-bold mt-2 mb-4">{title}</h1>
        <div class="flex items-center gap-3 text-sm text-[--color-text-muted]">
          <span class="font-mono">{date}</span>
          <span class="text-[--color-border]">|</span>
          <span>{author}</span>
        </div>
      </div>

      <div class="prose">
        <slot />
      </div>


      <!-- Article end CTA -->
      <div class="mt-12 border-t border-[--color-border] pt-8">
        {matchedPreset ? (
          <div class="border border-[--color-accent]/30 rounded-lg p-6 bg-[--color-bg-card] text-center">
            <p class="font-mono text-[--color-accent] text-xs mb-2">TRY IT YOURSELF</p>
            <h3 class="font-bold text-lg mb-2">Test {matchedPreset.label} on 569+ Coins</h3>
            <p class="text-[--color-text-muted] text-sm mb-4">Apply what you just learned. Run a backtest with the {matchedPreset.label} preset — no code, no signup.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href={`/simulate?preset=${matchedPreset.preset}`} class="btn btn-primary btn-md">
                Open {matchedPreset.label} Preset &rarr;
              </a>
              <a href="/simulate" class="btn btn-ghost btn-md">
                Build Custom Strategy
              </a>
            </div>
          </div>
        ) : (
          <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
            <h3 class="font-bold text-lg mb-2">Ready to test strategies yourself?</h3>
            <p class="text-[--color-text-muted] text-sm mb-4">Simulate trading strategies on 569+ coins with 2+ years of data. Free, no signup.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/simulate" class="btn btn-primary btn-md">
                Try the Simulator &rarr;
              </a>
              <a href="/fees" class="btn btn-ghost btn-md">
                Save on Fees
              </a>
            </div>
          </div>
        )}
      </div>
    </div>
  </article>
</Layout>
