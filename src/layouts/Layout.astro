    <script type="module" src="/scripts/layout-client.js" defer></script>
    <script is:inline>
      /* Theme toggle (PR-4 of light-mode rollout).
         FOUC-prevention head script (PR-5) sets data-theme before paint;
         this handler only owns user clicks + icon swap. */
      (function() {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        var sun = btn.querySelector('.theme-icon-sun');
        var moon = btn.querySelector('.theme-icon-moon');
        function syncIcon() {
          var isLight = document.documentElement.getAttribute('data-theme') === 'light';
          btn.setAttribute('aria-pressed', isLight ? 'true' : 'false');
          if (sun && moon) {
            sun.classList.toggle('hidden', isLight);
            moon.classList.toggle('hidden', !isLight);
          }
        }
        syncIcon();
        btn.addEventListener('click', function() {
          var isLight = document.documentElement.getAttribute('data-theme') === 'light';
          if (isLight) {
            document.documentElement.removeAttribute('data-theme');
            try { localStorage.setItem('pruviq-theme', 'dark'); } catch (_) {}
          } else {
            document.documentElement.setAttribute('data-theme', 'light');
            try { localStorage.setItem('pruviq-theme', 'light'); } catch (_) {}
          }
          syncIcon();
        });
      })();
    </script>
    <script is:inline define:vars={{ lang: lang }}>
      /* W5-3.2: G-prefix vim-style navigation shortcuts (Linear/GitHub).
         Press G, then within 1.5s press a destination key:
           H=home · S=simulate · C=coins · L=strategies ·
           R=ranking · P=performance · F=fees · B=blog · M=market
         Lang-aware: ko paths get /ko prefix automatically.
         Visual hint pill shows "Go to…" in upper-right while g-mode active.
         Escape or timeout cancels. */
      (function() {
        var routes = {
          h: '/',
          s: '/simulate',
          c: '/coins',
          l: '/strategies',
          r: '/strategies/ranking',
          p: '/performance',
          f: '/fees',
          b: '/blog',
          m: '/market',
        };
        var TIMEOUT_MS = 1500;
        var gMode = false;
        var timer = null;
        var hint = null;

        function localizedPath(path) {
          if (lang === 'ko') {
            return path === '/' ? '/ko/' : '/ko' + path;
          }
          return path;
        }

        function showHint() {
          if (hint) return;
          hint = document.createElement('div');
          hint.setAttribute('role', 'status');
          hint.setAttribute('aria-live', 'polite');
          hint.style.cssText =
            'position:fixed;top:1rem;right:1rem;z-index:130;' +
            'padding:.5rem .75rem;border-radius:.5rem;' +
            'background:var(--color-bg-elevated);' +
            'border:1px solid var(--color-accent);' +
            'color:var(--color-text);' +
            'font-family:JetBrains Mono,ui-monospace,monospace;' +
            'font-size:11px;font-weight:600;letter-spacing:.05em;' +
            'text-transform:uppercase;' +
            'box-shadow:var(--shadow-md);' +
            'pointer-events:none;';
          hint.textContent = lang === 'ko' ? 'GO TO… (h s c l r p f b m)' : 'GO TO… (h s c l r p f b m)';
          document.body.appendChild(hint);
        }
        function hideHint() {
          if (!hint) return;
          hint.parentNode && hint.parentNode.removeChild(hint);
          hint = null;
        }
        function exitGMode() {
          gMode = false;
          if (timer) { clearTimeout(timer); timer = null; }
          hideHint();
        }
        function isEditable(target) {
          if (!target) return false;
          var tag = target.tagName;
          if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT') return true;
          return !!target.isContentEditable;
        }

        document.addEventListener('keydown', function(e) {
          if (e.metaKey || e.ctrlKey || e.altKey) return;
          if (isEditable(e.target)) return;

          if (gMode) {
            if (e.key === 'Escape') {
              e.preventDefault();
              exitGMode();
              return;
            }
            var k = (e.key || '').toLowerCase();
            if (Object.prototype.hasOwnProperty.call(routes, k)) {
              e.preventDefault();
              var path = localizedPath(routes[k]);
              exitGMode();
              window.location.href = path;
              return;
            }
            // Any other key cancels g-mode
            exitGMode();
            return;
          }

          // Enter g-mode on lowercase 'g' (Shift+G is reserved for browsers)
          if (e.key === 'g' && !e.shiftKey) {
            e.preventDefault();
            gMode = true;
            showHint();
            timer = setTimeout(exitGMode, TIMEOUT_MS);
          }
        });
      })();
    </script>
    <script>
      /* Sticky CTA bar - show after scrolling past hero (mobile only) */
      (function() {
        var bar = document.getElementById('sticky-cta');
        var dismiss = document.getElementById('sticky-cta-dismiss');
        if (!bar) return;
        var shown = false;
        var dismissed = false;
        function check() {
          if (dismissed) return;
          var shouldShow = window.scrollY > 400;
          if (shouldShow !== shown) {
            shown = shouldShow;
            bar.style.transform = shown ? 'translateY(0)' : 'translateY(100%)';
          }
        }
        window.addEventListener('scroll', check, { passive: true });
        if (dismiss) {
          dismiss.addEventListener('click', function() {
            dismissed = true;
            bar.style.transform = 'translateY(100%)';
          });
        }
      })();
    </script>
    <!-- Sticky bottom CTA bar (non-simulator pages only) -->
    {!basePath.startsWith('/simulate') && (
      <div id="bottom-cta-bar" data-hide-in-hero class="fixed bottom-0 left-0 right-0 z-40 border-t border-[--color-border] bg-[--color-bg-elevated] transition-transform duration-300 translate-y-full" style="height:48px;" role="complementary" aria-label="Try simulator">
        <div class="max-w-7xl mx-auto px-6 lg:px-10 h-full flex items-center justify-between gap-3">
          <p class="text-sm text-[--color-text-muted] truncate">
            {lang === 'ko' ? `${C}+ 코인에서 전략 테스트` : `Test your strategy on ${C}+ coins`}
          </p>
          <div class="flex items-center gap-2 shrink-0">
            <a href={simulatePath} class="btn btn-primary btn-sm no-underline whitespace-nowrap text-xs">
              {lang === 'ko' ? '무료 시작 →' : 'Start Free →'}
            </a>
            <button id="bottom-cta-dismiss" aria-label="Dismiss" class="w-11 h-11 flex items-center justify-center rounded text-[--color-text-muted] hover:text-[--color-text] hover:bg-[--color-bg-hover] transition-colors">
              <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M2 2l10 10M12 2L2 12"/></svg>
            </button>
          </div>
        </div>
      </div>
    )}
    <script>
      /* Bottom CTA bar — show if user hasn't visited /simulate yet */
      (function() {
        var bar = document.getElementById('bottom-cta-bar');
        if (!bar) return;
        if (localStorage.getItem('visited-simulator') || localStorage.getItem('bottom-cta-dismissed')) return;
        var cookieNotice = document.getElementById('cookie-notice');
        function tryShow() {
          if (cookieNotice && cookieNotice.style.display !== 'none' && window.innerWidth < 640) return;
          bar.style.transform = 'translateY(0)';
        }
        setTimeout(tryShow, 1500);
        /* Hide near footer */
        var footer = document.querySelector('footer');
        if (footer && window.IntersectionObserver) {
          new IntersectionObserver(function(entries) {
            entries.forEach(function(e) {
              if (e.isIntersecting) bar.style.transform = 'translateY(100%)';
              else if (shown) bar.style.transform = 'translateY(0)';
            });
          }, { threshold: 0.1 }).observe(footer);
        }
        var dismiss = document.getElementById('bottom-cta-dismiss');
        if (dismiss) {
          dismiss.addEventListener('click', function() {
            localStorage.setItem('bottom-cta-dismissed', '1');
            bar.style.transform = 'translateY(100%)';
          });
        }
      })();
      /* Mark visited-simulator when user lands on /simulate */
      if (window.location.pathname.match(/\/(ko\/)?simulate/)) {
        localStorage.setItem('visited-simulator', '1');
      }
    </script>

    <!-- Cookie notice removed: no tracking, no ads, essential security cookies only -->
    {cfToken && (
      <>
        <script>
          /* Lazy-load Cloudflare beacon loader during idle or after load to reduce main-thread work */
          (function() {
            function loadCF() {
              try {
                var s = document.createElement('script');
                s.type = 'module';
                s.src = '/scripts/cf-beacon-loader.js';
                s.defer = true;
                document.body.appendChild(s);
              } catch (e) { /* ignore */ }
            }
            if (typeof window !== 'undefined') {
              if ('requestIdleCallback' in window) {
                requestIdleCallback(loadCF, { timeout: 2000 });
              } else {
                window.addEventListener('load', loadCF);
                setTimeout(loadCF, 2000);
              }
            }
          })();
        </script>
      </>
    )}
    <script>
      (function() {
        var els = document.querySelectorAll('.reveal, .reveal-child');
        if (!els.length) return;
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        els.forEach(function(el) { observer.observe(el); });
      })();
    </script>
  </body>
