---
/**
 * EmptyStateIllustration.astro — Brand-on illustration system for empty/error states.
 *
 * One typed primitive that swaps variants. SSR-friendly (.astro), tokens-only,
 * and fully theme-adaptive (light/dark) via CSS custom properties.
 *
 * Variants (W5-1 starter set — extend in follow-up PRs):
 *   broken-chart      404 page · "the path ended here" — 4 candles + 1 fragmented
 *   no-data           empty result list · flat zero line + ghost candles
 *   alert-storm       500/error · stylized lightning over a chart
 *   off-grid          maintenance · flat grid with one missing tile
 *
 * The illustrations use the same trading vocabulary (candlesticks, grids, signal
 * lines) as the rest of PRUVIQ — empty states feel like part of the product
 * surface rather than generic stock illustrations.
 *
 * Sizing: defaults to 200×140; pass `size` prop or `class` for full-bleed.
 * a11y: decorative by default (aria-hidden); pass `ariaLabel` for descriptive use.
 */

export interface Props {
  variant?: "broken-chart" | "no-data" | "alert-storm" | "off-grid";
  size?: number;
  ariaLabel?: string;
  class?: string;
}

const {
  variant = "broken-chart",
  size = 200,
  ariaLabel,
  class: className = "",
} = Astro.props;

const aspectHeight = Math.round(size * 0.7);
const isDecorative = !ariaLabel;
---

<svg
  viewBox={`0 0 ${size} ${aspectHeight}`}
  width={size}
  height={aspectHeight}
  role={isDecorative ? "presentation" : "img"}
  aria-hidden={isDecorative ? "true" : undefined}
  aria-label={ariaLabel}
  class={`empty-state-illustration ${className}`.trim()}
>
  {variant === "broken-chart" && (
    <>
      {/* Subtle grid backdrop */}
      <g style="stroke: var(--color-text-tertiary); stroke-width: 0.5; stroke-dasharray: 2 4; opacity: 0.4;">
        <line x1="0" y1="35" x2={size} y2="35" />
        <line x1="0" y1="70" x2={size} y2="70" />
        <line x1="0" y1="105" x2={size} y2="105" />
      </g>
      {/* Candle 1 — green up */}
      <g>
        <line x1="30" y1="40" x2="30" y2="100" style="stroke: var(--color-up); stroke-width: 1;" />
        <rect x="24" y="55" width="12" height="35" rx="1" style="fill: var(--color-up);" opacity="0.85" />
      </g>
      {/* Candle 2 — red down */}
      <g>
        <line x1="60" y1="50" x2="60" y2="115" style="stroke: var(--color-down); stroke-width: 1;" />
        <rect x="54" y="65" width="12" height="40" rx="1" style="fill: var(--color-down);" opacity="0.85" />
      </g>
      {/* Candle 3 — green up */}
      <g>
        <line x1="90" y1="30" x2="90" y2="95" style="stroke: var(--color-up); stroke-width: 1;" />
        <rect x="84" y="45" width="12" height="40" rx="1" style="fill: var(--color-up);" opacity="0.85" />
      </g>
      {/* Candle 4 — red down */}
      <g>
        <line x1="120" y1="40" x2="120" y2="105" style="stroke: var(--color-down); stroke-width: 1;" />
        <rect x="114" y="55" width="12" height="40" rx="1" style="fill: var(--color-down);" opacity="0.85" />
      </g>
      {/* Candle 5 — fragmented (the "404" — path ended here) */}
      <g style="opacity: 0.4;">
        <rect x="144" y="60" width="12" height="8" rx="1" style="fill: var(--color-text-tertiary);" />
        <rect x="144" y="74" width="12" height="6" rx="1" style="fill: var(--color-text-tertiary);" opacity="0.6" />
        <rect x="144" y="86" width="12" height="4" rx="1" style="fill: var(--color-text-tertiary);" opacity="0.3" />
      </g>
      {/* Dotted continuation hint — shows where the chart "would" go */}
      <line
        x1="156"
        y1="80"
        x2={size - 8}
        y2="80"
        style="stroke: var(--color-text-tertiary); stroke-width: 1; stroke-dasharray: 2 3;"
        opacity="0.3"
      />
      {/* Endpoint indicator — small accent dot at the broken transition */}
      <circle
        cx="150"
        cy="78"
        r="2.5"
        style="fill: var(--color-accent);"
        opacity="0.7"
      />
    </>
  )}

  {variant === "no-data" && (
    <>
      {/* Flat zero baseline + 4 ghost candles in muted gray */}
      <line
        x1="0"
        y1={aspectHeight / 2}
        x2={size}
        y2={aspectHeight / 2}
        style="stroke: var(--color-text-tertiary); stroke-width: 1; stroke-dasharray: 4 3;"
        opacity="0.5"
      />
      {[40, 80, 120, 160].map((cx) => (
        <rect
          x={cx - 6}
          y={aspectHeight / 2 - 2}
          width="12"
          height="4"
          rx="1"
          style="fill: var(--color-text-tertiary);"
          opacity="0.3"
        />
      ))}
    </>
  )}

  {variant === "alert-storm" && (
    <>
      {/* Lightning bolt over ghost chart */}
      <g style="opacity: 0.3;">
        <rect x="20" y="60" width="10" height="35" rx="1" style="fill: var(--color-text-tertiary);" />
        <rect x="50" y="50" width="10" height="50" rx="1" style="fill: var(--color-text-tertiary);" />
        <rect x="80" y="65" width="10" height="35" rx="1" style="fill: var(--color-text-tertiary);" />
      </g>
      <path
        d="M 130 30 L 145 60 L 135 65 L 155 110 L 140 75 L 150 70 Z"
        style="fill: var(--color-down);"
        opacity="0.85"
      />
    </>
  )}

  {variant === "off-grid" && (
    <>
      {/* 4×3 grid of tiles, one tile missing */}
      {[0, 1, 2, 3].map((col) =>
        [0, 1, 2].map((row) => {
          const isMissing = col === 2 && row === 1;
          if (isMissing) return null;
          return (
            <rect
              x={20 + col * 42}
              y={20 + row * 36}
              width="32"
              height="26"
              rx="2"
              style="fill: var(--color-bg-elevated); stroke: var(--color-border);"
              stroke-width="1"
            />
          );
        }),
      )}
      {/* Missing tile — dashed outline */}
      <rect
        x={20 + 2 * 42}
        y={20 + 1 * 36}
        width="32"
        height="26"
        rx="2"
        style="fill: none; stroke: var(--color-accent); stroke-dasharray: 2 3;"
        stroke-width="1"
        opacity="0.6"
      />
    </>
  )}
</svg>
