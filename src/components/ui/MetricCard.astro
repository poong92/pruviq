---
interface Props {
  value: string;
  label: string;
  color?: string;
}
const { value, label, color = 'var(--color-text)' } = Astro.props;
---
<div class="text-center">
  <p class="text-2xl md:text-3xl font-bold font-mono" style={`color: ${color}`}>{value}</p>
  <p class="text-sm text-[--color-text-muted] mt-1">{label}</p>
</div>
