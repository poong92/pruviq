---
import Layout from "../../../layouts/Layout.astro";
import SimulatorV2 from "../../../components/simulator/v2/SimulatorV2";
import { useTranslations } from "../../../i18n/index";

const t = useTranslations("en");
const title = "PRUVIQ Simulator v2 — Click a preset, see proof";
const description =
  "Quick-Start crypto strategy simulator. Click a preset, see a real backtest, compare it to our live OKX results. 7 curated presets, 240+ coins.";
---

<Layout title={title} description={description}>
  <meta slot="head" name="robots" content="noindex, nofollow" />
  <main class="min-h-screen bg-zinc-950">
    <SimulatorV2 client:only="preact" lang="en" />
  </main>
</Layout>
