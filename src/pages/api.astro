---
import Layout from '../layouts/Layout.astro';
import ApiEndpoint from '../components/ApiEndpoint.astro';
import { useTranslations } from '../i18n/index';

const t = useTranslations('en');
const API_BASE = 'https://api.pruviq.com';
---

<Layout title={t('meta.api_title')} description={t('meta.api_desc')}>

  <!-- HERO -->
  <section class="pt-4 pb-8">
    <div class="max-w-5xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('api.tag')}</p>
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        {t('api.title')}<br/><span class="text-[--color-accent]">{t('api.title2')}</span>
      </h1>
      <p class="text-[--color-text-muted] text-lg max-w-2xl">
        {t('api.desc')}
      </p>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- OVERVIEW -->
  <section class="reveal pb-12 pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <div class="reveal grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
        <div class="border border-[--color-border] rounded-lg p-4 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-1">{t('api.base_url')}</div>
          <code class="text-sm text-[--color-text] break-all">{API_BASE}</code>
        </div>
        <div class="border border-[--color-border] rounded-lg p-4 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-1">{t('api.rate_limit')}</div>
          <p class="text-sm text-[--color-text-muted]">{t('api.rate_limit_value')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-4 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-1">{t('api.auth')}</div>
          <p class="text-sm text-[--color-text-muted]">{t('api.auth_value')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-4 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-1">{t('api.format')}</div>
          <p class="text-sm text-[--color-text-muted]">{t('api.format_value')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-4 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-1">{t('api.cors')}</div>
          <p class="text-sm text-[--color-text-muted]">{t('api.cors_value')}</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-4 bg-[--color-bg-card]">
          <div class="font-mono text-[--color-accent] text-xs font-bold mb-1">{t('api.interactive')}</div>
          <p class="text-sm text-[--color-text-muted]">{t('api.interactive_desc')}</p>
          <a href={`${API_BASE}/docs`} target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-[--color-accent] hover:underline">/docs</a>
          <span class="text-[--color-text-muted] mx-1">|</span>
          <a href={`${API_BASE}/redoc`} target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-[--color-accent] hover:underline">/redoc</a>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- API Sidebar Navigation (desktop) -->
  <nav id="api-sidebar" class="hidden xl:block fixed left-[max(1rem,calc(50%-40rem))] top-24 w-48 text-sm z-40" aria-label="API sections">
    <p class="font-mono text-[--color-text-disabled] text-xs uppercase tracking-wider mb-3">Endpoints</p>
    <ul class="space-y-1.5 border-l border-[--color-border] pl-3">
      <li><a href="#market-data" class="block text-[--color-text-muted] hover:text-[--color-accent] transition-colors no-underline py-0.5">Market Data</a></li>
      <li><a href="#data-retrieval" class="block text-[--color-text-muted] hover:text-[--color-accent] transition-colors no-underline py-0.5">Data Retrieval</a></li>
      <li><a href="#signals" class="block text-[--color-text-muted] hover:text-[--color-accent] transition-colors no-underline py-0.5">Signals</a></li>
      <li><a href="#simulation" class="block text-[--color-text-muted] hover:text-[--color-accent] transition-colors no-underline py-0.5">Simulation</a></li>
      <li><a href="#builder" class="block text-[--color-text-muted] hover:text-[--color-accent] transition-colors no-underline py-0.5">Builder</a></li>
      <li><a href="#quickstart" class="block text-[--color-text-muted] hover:text-[--color-accent] transition-colors no-underline py-0.5">Quick Start</a></li>
    </ul>
  </nav>

  <!-- ENDPOINTS: MARKET DATA -->
  <section id="market-data" class="reveal pb-12 pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-6">{t('api.section_market')}</h2>
      <div class="space-y-4 max-w-4xl">

        <ApiEndpoint
          method="GET"
          path="/health"
          description={t('api.endpoint_health')}
          tryUrl={`${API_BASE}/health`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/health`}
          response={`{
  "status": "ok",
  "version": "0.3.0",
  "coins_loaded": 572,
  "uptime_seconds": 415785.5
}`}
        />

        <ApiEndpoint
          method="GET"
          path="/market"
          description={t('api.endpoint_market')}
          tryUrl={`${API_BASE}/market`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/market`}
          response={`{
  "btc_price": 66658.4,
  "btc_change_24h": -0.29,
  "eth_price": 2054.17,
  "eth_change_24h": -0.92,
  "fear_greed_index": 9,
  "fear_greed_label": "Extreme Fear",
  "total_market_cap_b": 2377.4,
  "btc_dominance": 56.1,
  "total_volume_24h_b": 93.5,
  "top_gainers": [ ... ],
  "top_losers": [ ... ],
  "extreme_funding": [ ... ]
}`}
        />

        <ApiEndpoint
          method="GET"
          path="/news"
          description={t('api.endpoint_news')}
          tryUrl={`${API_BASE}/news`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/news`}
          response={`[
  {
    "title": "Bitcoin drops below $67K amid macro uncertainty",
    "source": "CoinDesk",
    "url": "https://...",
    "published": "2026-04-03T10:30:00Z"
  },
  ...
]`}
        />

        <ApiEndpoint
          method="GET"
          path="/macro"
          description={t('api.endpoint_macro')}
          tryUrl={`${API_BASE}/macro`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/macro`}
          response={`{
  "dxy": { "value": 104.2, "change": -0.3 },
  "us10y": { "value": 4.25, "change": 0.02 },
  "sp500": { "value": 5280, "change": -1.2 },
  "open_interest": { ... },
  "funding_rates": { ... },
  "events": [ ... ]
}`}
        />

      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ENDPOINTS: DATA -->
  <section id="data-retrieval" class="reveal pb-12 pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-6">{t('api.section_data')}</h2>
      <div class="space-y-4 max-w-4xl">

        <ApiEndpoint
          method="GET"
          path="/coins"
          description={t('api.endpoint_coins')}
          tryUrl={`${API_BASE}/coins`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/coins`}
          response={`[
  {
    "symbol": "BTCUSDT",
    "rows": 19800,
    "date_from": "2023-12-30",
    "date_to": "2026-04-03"
  },
  {
    "symbol": "ETHUSDT",
    "rows": 19800,
    "date_from": "2023-12-30",
    "date_to": "2026-04-03"
  },
  ... // 572 coins total
]`}
        />

        <ApiEndpoint
          method="GET"
          path="/coins/stats"
          description={t('api.endpoint_coins_stats')}
          tryUrl={`${API_BASE}/coins/stats`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/coins/stats`}
          response={`[
  {
    "symbol": "BTCUSDT",
    "price": 66658.4,
    "volume_24h": 28500000000,
    "win_rate": 68.6,
    "profit_factor": 2.22,
    "total_trades": 142
  },
  ...
]`}
        />

        <ApiEndpoint
          method="GET"
          path="/ohlcv/{symbol}"
          description={t('api.endpoint_ohlcv')}
          params="symbol (path, required), limit (query, default: 3000)"
          tryUrl={`${API_BASE}/ohlcv/BTCUSDT?limit=5`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl "${API_BASE}/ohlcv/BTCUSDT?limit=168"`}
          response={`{
  "symbol": "BTCUSDT",
  "timeframe": "1H",
  "total_bars": 168,
  "data": [
    {
      "t": 1775178000,
      "o": 66761.8,
      "h": 66881.3,
      "l": 66450.0,
      "c": 66599.0,
      "v": 4087.42,
      "bb_upper": 67266.78,
      "bb_lower": 66077.55,
      "bb_mid": 66672.17,
      "ema20": 66865.21,
      "ema50": 67163.85,
      "vol_ratio": 0.9
    },
    ...
  ]
}`}
        />

        <ApiEndpoint
          method="GET"
          path="/strategies"
          description={t('api.endpoint_strategies')}
          tryUrl={`${API_BASE}/strategies`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/strategies`}
          response={`[
  {
    "id": "bb-squeeze-short",
    "name": "BB Squeeze SHORT",
    "description": "Bollinger Band squeeze breakout. Enters short on volatility expansion after contraction.",
    "default_params": {
      "sl_pct": 10.0,
      "tp_pct": 8.0,
      "max_bars": 48,
      "direction": "short",
      "status": "verified"
    }
  },
  ...
]`}
        />

        <ApiEndpoint
          method="GET"
          path="/indicators"
          description={t('api.endpoint_indicators')}
          tryUrl={`${API_BASE}/indicators`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/indicators`}
          response={`{
  "bb": {
    "name": "Bollinger Bands",
    "fields": ["bb_upper", "bb_lower", "bb_mid", "bb_width", "is_squeeze", ...],
    "default_params": { "period": 20, "std": 2.0 }
  },
  "ema": {
    "name": "EMA Trend",
    "fields": ["ema_fast", "ema_slow", "uptrend", "downtrend"],
    "default_params": { "fast": 9, "slow": 21 }
  },
  ...
}`}
        />

      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ENDPOINTS: RANKINGS & SIGNALS -->
  <section id="signals" class="reveal pb-12 pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-6">{t('api.section_signals')}</h2>
      <div class="space-y-4 max-w-4xl">

        <ApiEndpoint
          method="GET"
          path="/rankings/daily"
          description={t('api.endpoint_rankings_daily')}
          tryUrl={`${API_BASE}/rankings/daily`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/rankings/daily`}
          response={`{
  "date": "2026-04-03",
  "generated_at": "2026-04-03T00:27:22Z",
  "period": "30d",
  "group": "top50",
  "top3": [
    {
      "rank": 1,
      "name_en": "Keltner Squeeze LONG 6H",
      "strategy": "keltner-squeeze",
      "direction": "long",
      "win_rate": 54.17,
      "profit_factor": 1.78,
      "total_return": 0.58,
      "total_trades": 24,
      "sharpe": 3.19,
      "max_drawdown": 0.34,
      "rank_change": 0,
      "streak": 3
    },
    ...
  ]
}`}
        />

        <ApiEndpoint
          method="GET"
          path="/signals/live"
          description={t('api.endpoint_signals_live')}
          tryUrl={`${API_BASE}/signals/live`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/signals/live`}
          response={`[
  {
    "strategy": "ma-cross",
    "strategy_name": "MA Cross",
    "coin": "ETHUSDT",
    "direction": "short",
    "signal_time": "2026-04-03T02:00:00",
    "entry_price": 2049.44,
    "status": "verified",
    "sl_pct": 5,
    "tp_pct": 10
  },
  {
    "strategy": "heikin-ashi",
    "strategy_name": "Heikin Ashi Trend",
    "coin": "BEAMXUSDT",
    "direction": "long",
    "signal_time": "2026-04-03T02:00:00",
    "entry_price": 0.00171,
    "status": "research",
    "sl_pct": 7,
    "tp_pct": 8
  },
  ...
]`}
        />

        <ApiEndpoint
          method="GET"
          path="/hot-strategies"
          description={t('api.endpoint_hot_strategies')}
          tryUrl={`${API_BASE}/hot-strategies`}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          curl={`curl ${API_BASE}/hot-strategies`}
          response={`{
  "strategies": [
    {
      "strategy_id": "supertrend",
      "strategy_name": "SuperTrend",
      "direction": "short",
      "status": "research",
      "period": "30d",
      "profit_factor": 4.11,
      "win_rate": 60.0,
      "total_trades": 5,
      "total_return_pct": 5.9
    },
    ...
  ]
}`}
        />

      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ENDPOINTS: SIMULATION -->
  <section id="simulation" class="reveal pb-12 pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-6">{t('api.section_simulation')}</h2>
      <div class="space-y-4 max-w-4xl">

        <ApiEndpoint
          method="POST"
          path="/simulate"
          description={t('api.endpoint_simulate')}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          requestBodyLabel={t('api.request_body')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          requestBody={`{
  "strategy": "bb-squeeze-short",
  "sl_pct": 10.0,
  "tp_pct": 8.0,
  "max_bars": 48,
  "market_type": "futures",
  "top_n": 50
}`}
          curl={`curl -X POST ${API_BASE}/simulate \\
  -H "Content-Type: application/json" \\
  -d '{"strategy":"bb-squeeze-short","sl_pct":10,"tp_pct":8,"top_n":50}'`}
          response={`{
  "strategy": "bb-squeeze-short",
  "direction": "short",
  "total_trades": 1247,
  "win_rate": 68.6,
  "profit_factor": 2.22,
  "total_return_pct": 142.5,
  "sharpe_ratio": 3.45,
  "max_drawdown_pct": 8.2,
  "avg_bars_held": 12.3,
  "equity_curve": [ ... ]
}`}
        />

        <ApiEndpoint
          method="POST"
          path="/simulate/coin"
          description={t('api.endpoint_simulate_coin')}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          requestBodyLabel={t('api.request_body')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          requestBody={`{
  "symbol": "BTCUSDT",
  "sl_pct": 10.0,
  "tp_pct": 8.0,
  "max_bars": 48,
  "direction": "short",
  "market_type": "futures"
}`}
          curl={`curl -X POST ${API_BASE}/simulate/coin \\
  -H "Content-Type: application/json" \\
  -d '{"symbol":"BTCUSDT","sl_pct":10,"tp_pct":8,"max_bars":48,"direction":"short","market_type":"futures"}'`}
          response={`{
  "symbol": "BTCUSDT",
  "total_trades": 42,
  "win_rate": 71.4,
  "profit_factor": 2.85,
  "trades": [
    {
      "entry_time": "2025-06-15T14:00:00",
      "exit_time": "2025-06-16T02:00:00",
      "entry_price": 67500.0,
      "exit_price": 62100.0,
      "pnl_pct": 8.0,
      "result": "tp"
    },
    ...
  ]
}`}
        />

        <ApiEndpoint
          method="POST"
          path="/simulate/compare"
          description={t('api.endpoint_compare')}
          note={t('api.note_async')}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          requestBodyLabel={t('api.request_body')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          requestBody={`{
  "sl_pct": 10.0,
  "tp_pct": 8.0,
  "max_bars": 48,
  "top_n": 50
}`}
          curl={`curl -X POST ${API_BASE}/simulate/compare \\
  -H "Content-Type: application/json" \\
  -d '{"sl_pct":10,"tp_pct":8,"max_bars":48,"top_n":50}'`}
          response={`{
  "params": { "sl_pct": 10.0, "tp_pct": 8.0, "top_n": 50 },
  "results": [
    {
      "strategy": "bb-squeeze-short",
      "win_rate": 68.6,
      "profit_factor": 2.22,
      "total_trades": 1247,
      "sharpe": 3.45
    },
    {
      "strategy": "ma-cross-short",
      "win_rate": 55.2,
      "profit_factor": 1.45,
      "total_trades": 890,
      "sharpe": 1.82
    },
    ...
  ]
}`}
        />

        <ApiEndpoint
          method="POST"
          path="/simulate/validate"
          description={t('api.endpoint_validate')}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          requestBodyLabel={t('api.request_body')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          requestBody={`{
  "strategy": "bb-squeeze-short",
  "sl_pct": 10.0,
  "tp_pct": 8.0
}`}
          curl={`curl -X POST ${API_BASE}/simulate/validate \\
  -H "Content-Type: application/json" \\
  -d '{"strategy":"bb-squeeze-short","sl_pct":10,"tp_pct":8}'`}
          response={`{
  "valid": true,
  "strategy": "bb-squeeze-short",
  "warnings": []
}`}
        />

      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ENDPOINTS: STRATEGY BUILDER -->
  <section id="builder" class="reveal pb-12 pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-6">{t('api.section_builder')}</h2>
      <div class="space-y-4 max-w-4xl">

        <ApiEndpoint
          method="POST"
          path="/backtest"
          description={t('api.endpoint_backtest')}
          tryLabel={t('api.try_it')}
          curlLabel={t('api.curl_example')}
          responseLabel={t('api.response_example')}
          requestBodyLabel={t('api.request_body')}
          copyLabel={t('api.copy')}
          copiedLabel={t('api.copied')}
          requestBody={`{
  "name": "My Strategy",
  "direction": "short",
  "indicators": { "bb": {}, "volume": {} },
  "entry": {
    "type": "AND",
    "conditions": [
      { "field": "bb_squeeze", "op": "==", "value_bool": true },
      { "field": "vol_ratio", "op": ">", "value": 2.0 }
    ]
  },
  "sl_pct": 10.0,
  "tp_pct": 8.0,
  "max_bars": 48,
  "top_n": 50
}`}
          curl={`curl -X POST ${API_BASE}/backtest \\
  -H "Content-Type: application/json" \\
  -d '{"name":"My Strategy","direction":"short","indicators":{"bb":{},"volume":{}},"entry":{"type":"AND","conditions":[{"field":"bb_squeeze","op":"==","value_bool":true},{"field":"vol_ratio","op":">","value":2.0}]},"sl_pct":10,"tp_pct":8,"top_n":50}'`}
          response={`{
  "name": "My Strategy",
  "direction": "short",
