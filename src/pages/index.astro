---
import Layout from '../layouts/Layout.astro';
---

<Layout title="PRUVIQ - Algorithmic Crypto Trading, Verified by Data">

  <!-- HERO -->
  <section class="min-h-[90vh] flex items-center">
    <div class="max-w-6xl mx-auto px-4 py-20">
      <div class="max-w-3xl">
        <p class="font-mono text-[--color-accent] text-sm mb-4 tracking-wider">ALGORITHMIC TRADING</p>
        <h1 class="text-4xl md:text-6xl font-bold leading-tight mb-6">
          Crypto Trading,<br/>
          <span class="text-[--color-accent]">Verified by Data.</span>
        </h1>
        <p class="text-lg md:text-xl text-[--color-text-muted] mb-8 max-w-2xl">
          We don't predict. We execute. BB Squeeze SHORT strategy running 24/7 on 536 coins
          with transparent, verifiable performance data.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-12">
          <a href="https://t.me/PRUVIQ" target="_blank" rel="noopener"
             class="bg-[--color-accent] text-[--color-bg] px-8 py-3 rounded font-semibold text-center hover:bg-[--color-accent-dim] transition-colors">
            Join Community
          </a>
          <a href="#strategy"
             class="border border-[--color-border] text-[--color-text] px-8 py-3 rounded font-semibold text-center hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
            Learn Strategy
          </a>
        </div>

        <!-- Stats bar -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card]">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">32+</p>
            <p class="text-[--color-text-muted] text-sm">Days Live</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card]">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">1,199</p>
            <p class="text-[--color-text-muted] text-sm">Trades Executed</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card]">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">536</p>
            <p class="text-[--color-text-muted] text-sm">Coins Monitored</p>
          </div>
          <div class="border border-[--color-border] rounded p-4 bg-[--color-bg-card]">
            <p class="font-mono text-[--color-accent] text-2xl font-bold">24/7</p>
            <p class="text-[--color-text-muted] text-sm">Uptime</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- STRATEGY -->
  <section id="strategy" class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">STRATEGY</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">BB Squeeze SHORT</h2>
      <p class="text-[--color-text-muted] text-lg mb-12 max-w-2xl">
        Bollinger Band Squeeze detects volatility compression. When bands tighten and then expand
        with bearish signals, we enter short positions with strict risk management.
      </p>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- How it works -->
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <h3 class="font-mono text-[--color-accent] text-sm mb-4">HOW IT WORKS</h3>
          <div class="space-y-4 text-sm">
            <div class="flex gap-3">
              <span class="font-mono text-[--color-accent] shrink-0">01</span>
              <p><strong>Squeeze Detection</strong> &mdash; Bollinger Bands contract inside Keltner Channel, signaling low volatility</p>
            </div>
            <div class="flex gap-3">
              <span class="font-mono text-[--color-accent] shrink-0">02</span>
              <p><strong>Expansion Signal</strong> &mdash; Bands expand 10%+ with bearish candle pattern</p>
            </div>
            <div class="flex gap-3">
              <span class="font-mono text-[--color-accent] shrink-0">03</span>
              <p><strong>Volume Confirmation</strong> &mdash; Volume must exceed 2x average for entry</p>
            </div>
            <div class="flex gap-3">
              <span class="font-mono text-[--color-accent] shrink-0">04</span>
              <p><strong>Strict Risk Control</strong> &mdash; Every trade has predefined SL and TP</p>
            </div>
          </div>
        </div>

        <!-- Parameters -->
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <h3 class="font-mono text-[--color-accent] text-sm mb-4">PARAMETERS</h3>
          <div class="space-y-3 font-mono text-sm">
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Direction</span>
              <span>SHORT ONLY</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Stop Loss</span>
              <span class="text-[--color-red]">10%</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Take Profit</span>
              <span class="text-[--color-accent]">6%</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Volume Filter</span>
              <span>2.0x avg</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">BB Expansion</span>
              <span>&ge; 10%</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Leverage</span>
              <span>5x</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Max Hold Time</span>
              <span>48h</span>
            </div>
            <div class="flex justify-between">
              <span class="text-[--color-text-muted]">Time Filter</span>
              <span>7 hours blocked</span>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-8 border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
        <h3 class="font-mono text-[--color-accent] text-sm mb-4">WHY SHORT ONLY?</h3>
        <p class="text-[--color-text-muted] text-sm leading-relaxed">
          After extensive backtesting across 536 coins over 2+ years of data, BB Squeeze SHORT was the
          <strong class="text-[--color-text]">only consistently profitable direction</strong>.
          LONG strategies showed negative expected value due to structural market dynamics.
          We follow the data, not opinions. 6 independent expert analyses confirmed this conclusion.
        </p>
      </div>
    </div>
  </section>

  <!-- PERFORMANCE -->
  <section id="performance" class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">PERFORMANCE</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Transparent Results</h2>
      <p class="text-[--color-text-muted] text-lg mb-12 max-w-2xl">
        Every trade is tracked. Every loss is shown. We believe transparency builds trust.
      </p>

      <div class="grid md:grid-cols-3 gap-6 mb-8">
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
          <p class="text-[--color-text-muted] text-sm mb-2">Win Rate</p>
          <p class="font-mono text-4xl font-bold text-[--color-accent]">~55%</p>
          <p class="text-[--color-text-muted] text-xs mt-1">Live trading</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
          <p class="text-[--color-text-muted] text-sm mb-2">Backtest Win Rate</p>
          <p class="font-mono text-4xl font-bold text-[--color-accent]">59.3%</p>
          <p class="text-[--color-text-muted] text-xs mt-1">536 coins, 2+ years</p>
        </div>
        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
          <p class="text-[--color-text-muted] text-sm mb-2">Max Positions</p>
          <p class="font-mono text-4xl font-bold">100</p>
          <p class="text-[--color-text-muted] text-xs mt-1">$60 per position</p>
        </div>
      </div>

      <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
        <h3 class="font-mono text-[--color-accent] text-sm mb-4">RISK MANAGEMENT</h3>
        <div class="grid sm:grid-cols-3 gap-4 font-mono text-sm">
          <div>
            <span class="text-[--color-text-muted]">Daily Loss Limit</span>
            <p class="text-xl font-bold text-[--color-red]">7%</p>
          </div>
          <div>
            <span class="text-[--color-text-muted]">Max Drawdown</span>
            <p class="text-xl font-bold text-[--color-red]">20%</p>
          </div>
          <div>
            <span class="text-[--color-text-muted]">Position Size</span>
            <p class="text-xl font-bold">$60 x 5x</p>
          </div>
        </div>
      </div>

      <p class="text-[--color-text-muted] text-xs mt-4 italic">
        * Performance data is updated regularly by our AI system. Live results may differ from backtests.
      </p>
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">ABOUT</p>
      <h2 class="text-3xl md:text-4xl font-bold mb-8">Built by a Developer, for Traders</h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div>
          <p class="text-[--color-text-muted] leading-relaxed mb-6">
            PRUVIQ is built and operated by <strong class="text-[--color-text]">JPLee</strong>,
            a developer and algorithmic trader. Every line of code, every backtest, every deployment
            is done by one person with AI-powered tools.
          </p>
          <p class="text-[--color-text-muted] leading-relaxed mb-6">
            The philosophy is simple: <strong class="text-[--color-accent]">Evidence over hype.
            Risk before profit.</strong> In a market full of noise, we let data speak.
          </p>

          <div class="space-y-3">
            <h3 class="font-mono text-[--color-accent] text-sm">PRINCIPLES</h3>
            <div class="flex gap-3 text-sm">
              <span class="text-[--color-accent] font-mono shrink-0">&gt;</span>
              <p>Backtest first, trade second. Always.</p>
            </div>
            <div class="flex gap-3 text-sm">
              <span class="text-[--color-accent] font-mono shrink-0">&gt;</span>
              <p>Show losses too. Transparency builds trust.</p>
            </div>
            <div class="flex gap-3 text-sm">
              <span class="text-[--color-accent] font-mono shrink-0">&gt;</span>
              <p>Risk management is not optional.</p>
            </div>
            <div class="flex gap-3 text-sm">
              <span class="text-[--color-accent] font-mono shrink-0">&gt;</span>
              <p>Community learns together.</p>
            </div>
          </div>
        </div>

        <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card]">
          <h3 class="font-mono text-[--color-accent] text-sm mb-4">TECH STACK</h3>
          <div class="space-y-3 text-sm font-mono">
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Language</span>
              <span>Python</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Exchange</span>
              <span>Binance Futures</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Infrastructure</span>
              <span>Cloud VPS (24/7)</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">AI Analysis</span>
              <span>Mac Mini M4</span>
            </div>
            <div class="flex justify-between border-b border-[--color-border] pb-2">
              <span class="text-[--color-text-muted]">Backtesting</span>
              <span>Custom Engine</span>
            </div>
            <div class="flex justify-between">
              <span class="text-[--color-text-muted]">Alerts</span>
              <span>Telegram Bot</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 border-t border-[--color-border]">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Learn?</h2>
      <p class="text-[--color-text-muted] text-lg mb-8 max-w-xl mx-auto">
        Join our community to follow live performance, learn algorithmic trading,
        and access daily AI-generated market insights.
      </p>
      <a href="https://t.me/PRUVIQ" target="_blank" rel="noopener"
         class="inline-block bg-[--color-accent] text-[--color-bg] px-10 py-4 rounded font-semibold text-lg hover:bg-[--color-accent-dim] transition-colors">
        Join PRUVIQ on Telegram
      </a>
      <p class="text-[--color-text-muted] text-xs mt-4">Free to join. No financial advice provided.</p>
    </div>
  </section>

</Layout>
