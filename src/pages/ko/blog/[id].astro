---
import { getCollection, render } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const koPosts = await getCollection('blog-ko');
  const enPosts = await getCollection('blog');
  const koIds = new Set(koPosts.map(p => p.id));

  return [
    ...koPosts.map((post) => ({
      params: { id: post.id },
      props: { post, isKorean: true },
    })),
    ...enPosts.filter(p => !koIds.has(p.id)).map((post) => ({
      params: { id: post.id },
      props: { post, isKorean: false },
    })),
  ];
}

const { post, isKorean } = Astro.props;
const { Content } = await render(post);
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  date={post.data.date}
  category={post.data.category}
  author={post.data.author}
  image={post.data.image}
  body={post.body}
  tags={post.data.tags}
  postId={post.id}
  noAlternate={!isKorean}
  isKorean={isKorean}
>
  {!isKorean && (
    <div class="mb-6 px-3 py-2 border border-[--color-border] rounded bg-[--color-bg-card] text-sm text-[--color-text-muted]">
      This content is available in English only.
    </div>
  )}
  <Content />
</BlogPost>

<script define:vars={{ postId: post.id }}>
  try {
    const KEY = 'pruviq_learn_read';
    const raw = localStorage.getItem(KEY);
    const read = raw ? JSON.parse(raw) : [];
    if (!read.includes(postId)) {
      read.push(postId);
      localStorage.setItem(KEY, JSON.stringify(read));
    }
  } catch {}
</script>
