---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/index';

const t = useTranslations('ko');

export async function getStaticPaths() {
  const koPosts = await getCollection('blog-ko');
  const enPosts = await getCollection('blog');

  const koIds = new Set(koPosts.map(p => p.id));

  const paths = [
    ...koPosts.map((post) => ({
      params: { id: post.id },
      props: { post, isKorean: true },
    })),
    ...enPosts.filter(p => !koIds.has(p.id)).map((post) => ({
      params: { id: post.id },
      props: { post, isKorean: false },
    })),
  ];

  return paths;
}

const { post, isKorean } = Astro.props;
const { Content } = await render(post);

const categoryLabels: Record<string, string> = {
  market: t('blog.category.market'),
  quant: t('blog.category.quant'),
  strategy: t('blog.category.strategy'),
  weekly: t('blog.category.weekly'),
  education: t('blog.category.education'),
};

// Tag → simulator preset mapping
const tagPresetMap: Record<string, { preset: string; label: string; labelKo: string }> = {
  'rsi': { preset: 'rsi-reversal', label: 'RSI Reversal', labelKo: 'RSI 역전' },
  'macd': { preset: 'macd-cross', label: 'MACD Cross', labelKo: 'MACD 크로스' },
  'ema': { preset: 'ema-crossover', label: 'EMA Crossover', labelKo: 'EMA 크로스오버' },
  'bollinger-bands': { preset: 'bb-squeeze-short', label: 'BB Squeeze', labelKo: 'BB 스퀴즈' },
  'squeeze': { preset: 'bb-squeeze-short', label: 'BB Squeeze', labelKo: 'BB 스퀴즈' },
  'ichimoku': { preset: 'ichimoku', label: 'Ichimoku Cloud', labelKo: '이치모쿠 클라우드' },
  'stochastic': { preset: 'stochastic-rsi', label: 'Stochastic RSI', labelKo: '스토캐스틱 RSI' },
  'adx': { preset: 'adx-trend', label: 'ADX Trend', labelKo: 'ADX 트렌드' },
  'atr': { preset: 'atr-breakout', label: 'ATR Breakout', labelKo: 'ATR 브레이크아웃' },
  'volume': { preset: 'volume-breakout', label: 'Volume Breakout', labelKo: '거래량 브레이크아웃' },
};
const tags = post.data.tags || [];
const matchedPreset = tags.map((tg: string) => tagPresetMap[tg]).find(Boolean);
---

<Layout title={`${post.data.title} - PRUVIQ`} description={post.data.description} type="article" date={post.data.date} category={post.data.category} ogImage={post.data.image} noAlternate={!isKorean}>
  <article class="py-12">
    <div class="max-w-3xl mx-auto px-4">
      <a href="/ko/learn" class="text-[--color-text-muted] text-sm hover:text-[--color-accent] transition-colors mb-8 inline-block">
        &larr; {t('blog.back')}
      </a>

      {!isKorean && (
        <div class="mb-4 px-3 py-2 border border-[--color-border] rounded bg-[--color-bg-card] text-sm text-[--color-text-muted]">
          This content is available in English only.
        </div>
      )}

      <div class="mb-8">
        <span class="font-mono text-[--color-accent] text-xs tracking-wider">
          {categoryLabels[post.data.category] || post.data.category.toUpperCase()}
        </span>
        <h1 class="text-3xl md:text-4xl font-bold mt-2 mb-4">{post.data.title}</h1>
        <div class="flex items-center gap-3 text-sm text-[--color-text-muted]">
          <span class="font-mono">{post.data.date}</span>
          <span class="text-[--color-border]">|</span>
          <span>{post.data.author || 'PRUVIQ Research'}</span>
        </div>
      </div>

      <div class="prose">
        <Content />
      </div>


      <!-- Article end CTA -->
      <div class="mt-12 border-t border-[--color-border] pt-8">
        {matchedPreset ? (
          <div class="border border-[--color-accent]/30 rounded-lg p-6 bg-[--color-bg-card] text-center">
            <p class="font-mono text-[--color-accent] text-xs mb-2">직접 테스트</p>
            <h3 class="font-bold text-lg mb-2">569+ 코인에서 {matchedPreset.labelKo} 테스트</h3>
            <p class="text-[--color-text-muted] text-sm mb-4">방금 배운 내용을 적용해 보세요. {matchedPreset.labelKo} 프리셋으로 백테스트 — 코딩 없이, 가입 없이.</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href={`/ko/simulate?preset=${matchedPreset.preset}`} class="btn btn-primary btn-md">
                {matchedPreset.labelKo} 프리셋 열기 &rarr;
              </a>
              <a href="/ko/simulate" class="btn btn-ghost btn-md">
                커스텀 전략 만들기
              </a>
            </div>
          </div>
        ) : (
          <div class="border border-[--color-border] rounded-lg p-6 bg-[--color-bg-card] text-center">
            <h3 class="font-bold text-lg mb-2">{t('blog.cta_title')}</h3>
            <p class="text-[--color-text-muted] text-sm mb-4">{t('blog.cta_desc')}</p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/ko/simulate" class="btn btn-primary btn-md">
                {t('blog.cta_button')} &rarr;
              </a>
              <a href="/ko/fees" class="btn btn-ghost btn-md hover:border-[--color-accent] transition-colors">
                {t('blog.cta_fees')}
              </a>
            </div>
          </div>
        )}
      </div>
    </div>
  </article>

  <script define:vars={{ postId: post.id }}>
    try {
      const KEY = 'pruviq_learn_read';
      const raw = localStorage.getItem(KEY);
      const read = raw ? JSON.parse(raw) : [];
      if (!read.includes(postId)) {
        read.push(postId);
        localStorage.setItem(KEY, JSON.stringify(read));
      }
    } catch {}
  </script>
</Layout>
