---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/index';

const t = useTranslations('ko');

const TOP_COINS = [
  { symbol: 'BTC', name: '비트코인' },
  { symbol: 'ETH', name: '이더리움' },
  { symbol: 'BNB', name: 'BNB' },
  { symbol: 'SOL', name: '솔라나' },
  { symbol: 'XRP', name: 'XRP' },
  { symbol: 'DOGE', name: '도지코인' },
  { symbol: 'ADA', name: '카르다노' },
  { symbol: 'AVAX', name: '아발란체' },
  { symbol: 'DOT', name: '폴카닷' },
  { symbol: 'LINK', name: '체인링크' },
  { symbol: 'MATIC', name: '폴리곤' },
  { symbol: 'UNI', name: '유니스왑' },
  { symbol: 'ATOM', name: '코스모스' },
  { symbol: 'LTC', name: '라이트코인' },
  { symbol: 'FIL', name: '파일코인' },
  { symbol: 'APT', name: '앱토스' },
  { symbol: 'ARB', name: '아비트럼' },
  { symbol: 'OP', name: '옵티미즘' },
  { symbol: 'NEAR', name: '니어 프로토콜' },
  { symbol: 'SUI', name: '수이' },
  { symbol: 'AAVE', name: '에이브' },
  { symbol: 'INJ', name: '인젝티브' },
  { symbol: 'TIA', name: '셀레스티아' },
  { symbol: 'SEI', name: '세이' },
  { symbol: 'PEPE', name: '페페' },
  { symbol: 'WIF', name: 'dogwifhat' },
  { symbol: 'RENDER', name: '렌더' },
  { symbol: 'FET', name: 'Fetch.ai' },
  { symbol: 'RUNE', name: '토르체인' },
  { symbol: 'IMX', name: '이뮤터블 X' },
];
---

<Layout title={t('meta.coins_title')} description={t('meta.coins_desc')}>
  <section class="py-12">
    <div class="max-w-6xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">{t('coins.tag')}</p>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">{t('coins.title')}</h1>
      <p class="text-[--color-text-muted] text-lg mb-8 max-w-2xl">
        {t('coins.desc')}
      </p>
      <div id="coins-mount">
        <div class="animate-pulse space-y-4">
          <div class="h-10 bg-[--color-bg-hover] rounded w-1/3"></div>
          <div class="h-8 bg-[--color-bg-hover] rounded"></div>
          <div class="space-y-2">
            <div class="h-12 bg-[--color-bg-hover] rounded"></div>
            <div class="h-12 bg-[--color-bg-hover] rounded"></div>
            <div class="h-12 bg-[--color-bg-hover] rounded"></div>
            <div class="h-12 bg-[--color-bg-hover] rounded"></div>
            <div class="h-12 bg-[--color-bg-hover] rounded"></div>
          </div>
        </div>
        <noscript>
          <p class="text-sm text-[--color-text-muted] py-4">
            실시간 데이터는 JavaScript가 필요합니다. 개별 코인을 확인하세요:
          </p>
          <ul class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            {TOP_COINS.map(c => (
              <li>
                <a href={`/ko/coins/${c.symbol.toLowerCase()}usdt`} class="text-[--color-accent] hover:underline text-sm">
                  {c.name} ({c.symbol})
                </a>
              </li>
            ))}
          </ul>
        </noscript>
      </div>
      <div class="mt-10 pt-8 border-t border-[--color-border] text-center">
        <p class="text-[--color-text-muted] text-sm mb-4">{t('coins.explore_next')}</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href="/ko/simulate" class="inline-block bg-[--color-accent] text-[--color-bg] px-6 py-2.5 rounded font-semibold text-sm hover:opacity-90 transition-opacity no-underline">
            {t('cross.simulate_cta')} &rarr;
          </a>
          <a href="/ko/learn" class="inline-block border border-[--color-border] px-5 py-2 rounded font-semibold text-sm hover:border-[--color-accent] transition-colors no-underline">
            {t('cross.learn_cta')} &rarr;
          </a>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { h, render } from 'preact';
    import CoinListTable from '../../../components/CoinListTable';
    import ErrorBoundary from '../../../components/ErrorBoundary';

    const mount = document.getElementById('coins-mount');
    if (mount) {
      render(h(ErrorBoundary, { name: 'Coin List', lang: 'ko' }, h(CoinListTable, { lang: 'ko' })), mount);
    }
  </script>
</Layout>
