---
import Layout from '../../../layouts/Layout.astro';
import { useTranslations } from '../../../i18n/index';

const t = useTranslations('ko');
---

<Layout title="시뮬레이션 — 매매 전략 설계 & 백테스트 | PRUVIQ" description="코드 없이 매매 전략을 설계하세요. 지표를 선택하고, 조건을 설정하고, 535개 이상의 코인에서 2년 이상의 데이터로 백테스트를 실행하세요. 영원히 무료.">

  <!-- HERO -->
  <section class="py-16">
    <div class="max-w-5xl mx-auto px-4">
      <p class="font-mono text-[--color-accent] text-sm mb-2 tracking-wider">전략 시뮬레이터</p>
      <h1 class="text-3xl md:text-5xl font-bold mb-4">
        전략을 만들고,<br/>535개 코인에서 테스트하세요.
      </h1>
      <p class="text-[--color-text-muted] text-lg mb-6 max-w-2xl">
        지표를 선택하고, 진입 조건을 설정하고, 리스크 파라미터를 조정하세요.
        2년 이상의 실제 데이터로 백테스트를 실행하거나, 프리셋으로 시작하세요.
      </p>
      <p class="text-[--color-text-muted] text-xs">
        코드 불필요. 계정 불필요. 비용 없음. 결과에는 현실적인 수수료와 슬리피지가 포함됩니다.
      </p>
    </div>
  </section>

  <!-- STRATEGY BUILDER -->
  <section class="pb-12 border-t border-[--color-border] pt-8">
    <div class="max-w-5xl mx-auto px-4">
      <div id="builder-mount">
        <div class="border border-[--color-border] rounded-xl p-8 bg-[--color-bg-card] text-center">
          <div class="animate-pulse">
            <div class="h-3 w-32 bg-[--color-border] rounded mx-auto mb-3" />
            <div class="h-8 w-64 bg-[--color-border] rounded mx-auto mb-3" />
            <div class="h-4 w-96 max-w-full bg-[--color-border] rounded mx-auto" />
          </div>
          <p class="text-[--color-text-muted] text-sm mt-4">전략 빌더 로딩중...</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTED STRATEGIES -->
  <section class="pb-12 border-t border-[--color-border] pt-12">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-2">검증된 전략</h2>
      <p class="text-[--color-text-muted] text-sm mb-6">
        5개 전략 테스트. 4개 탈락. 1개 검증 완료. 전체 결과 공개.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/ko/strategies/bb-squeeze-short" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-green-500/10 text-green-400 border border-green-500/20">검증됨</span>
          </div>
          <h3 class="font-bold mb-1">BB Squeeze SHORT</h3>
          <p class="text-[--color-text-muted] text-xs mb-3">볼린저 밴드 변동성 확장 — 숏 방향</p>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div><span class="text-[--color-text-muted]">승률</span> <span class="font-mono font-bold text-[--color-accent] ml-1">70.4%</span></div>
            <div><span class="text-[--color-text-muted]">PF</span> <span class="font-mono font-bold text-[--color-accent] ml-1">2.55</span></div>
            <div><span class="text-[--color-text-muted]">거래수</span> <span class="font-mono ml-1">2,898</span></div>
            <div><span class="text-[--color-text-muted]">수익</span> <span class="font-mono font-bold text-green-400 ml-1">+$794</span></div>
          </div>
        </a>

        <a href="/ko/strategies/bb-squeeze-long" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-red-500/10 text-red-400 border border-red-500/20">탈락</span>
          </div>
          <h3 class="font-bold mb-1">BB Squeeze LONG</h3>
          <p class="text-[--color-text-muted] text-xs mb-3">동일 전략, 롱 방향 — 검증 실패</p>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div><span class="text-[--color-text-muted]">승률</span> <span class="font-mono ml-1">51%</span></div>
            <div><span class="text-[--color-text-muted]">PF</span> <span class="font-mono ml-1">0.98</span></div>
            <div><span class="text-[--color-text-muted]">거래수</span> <span class="font-mono ml-1">3,201</span></div>
            <div><span class="text-[--color-text-muted]">수익</span> <span class="font-mono text-red-400 ml-1">-$26</span></div>
          </div>
        </a>

        <a href="/ko/strategies/momentum-long" class="border border-[--color-border] rounded-lg p-5 bg-[--color-bg-card] card-hover block">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-red-500/10 text-red-400 border border-red-500/20">탈락</span>
          </div>
          <h3 class="font-bold mb-1">모멘텀 돌파 LONG</h3>
          <p class="text-[--color-text-muted] text-xs mb-3">20캔들 최고가 돌파 — 대규모 손실</p>
          <div class="grid grid-cols-2 gap-2 text-xs">
            <div><span class="text-[--color-text-muted]">승률</span> <span class="font-mono ml-1">37.5%</span></div>
            <div><span class="text-[--color-text-muted]">PF</span> <span class="font-mono ml-1">0.42</span></div>
            <div><span class="text-[--color-text-muted]">거래수</span> <span class="font-mono ml-1">1,842</span></div>
            <div><span class="text-[--color-text-muted]">수익</span> <span class="font-mono text-red-400 ml-1">-$14,115</span></div>
          </div>
        </a>
      </div>

      <div class="mt-4 text-center">
        <a href="/ko/strategies" class="text-sm text-[--color-text-muted] hover:text-[--color-accent] transition-colors">
          전체 5개 전략 보기 &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- DISCLAIMER -->
  <section class="pb-16">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <p class="text-[--color-text-muted] text-xs max-w-lg mx-auto">
        시뮬레이션에는 거래당 0.04% 선물 수수료 + 0.02% 슬리피지가 포함됩니다.
        과거 성과가 미래 수익을 보장하지 않습니다. 투자 조언이 아닙니다.
      </p>
    </div>
  </section>

</Layout>

<script>
  import { h, render } from 'preact';
  import StrategyBuilder from '../../../components/StrategyBuilder';

  const mount = document.getElementById('builder-mount');
  if (mount) {
    render(h(StrategyBuilder, { lang: 'ko' }), mount);
  }
</script>
