---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="404 - PRUVIQ" description="페이지를 찾을 수 없습니다">
  <div class="min-h-[60vh] flex flex-col items-center justify-center px-4 text-center">
    <p class="font-mono text-[--color-accent] text-sm tracking-widest mb-4">404</p>
    <h1 class="text-4xl font-bold mb-4">페이지를 찾을 수 없습니다</h1>
    <p class="text-[--color-text-muted] mb-8 max-w-md">
      찾으시는 페이지가 없거나 이동되었을 수 있습니다.
    </p>
    <div class="flex gap-4">
      <a href="/ko/" class="btn-primary bg-[--color-accent] text-[--color-bg] px-6 py-2 rounded font-semibold text-sm hover:bg-[--color-accent-dim]">
        홈
      </a>
      <a href="/ko/strategies" class="border border-[--color-border] px-6 py-2 rounded text-sm hover:border-[--color-accent] hover:text-[--color-accent] transition-colors">
        전략
      </a>
    </div>
  </div>
</Layout>
